# Bitbucket PR Manager MCP Server Configuration
# Copy this file to .env and fill in your values for local development
# In production, set these as actual environment variables

# Your Atlassian account email address
BITBUCKET_USERNAME=your.email@example.com

# API Token from Bitbucket (NOT app password)
# Create at: https://bitbucket.org/[workspace]/workspace/settings/app-passwords
BITBUCKET_API_TOKEN=ATCTT3xFf...

# Bitbucket workspace name
BITBUCKET_WORKSPACE=your-workspace

# Repository slug (the name in the URL)
BITBUCKET_REPO_SLUG=your-repo
